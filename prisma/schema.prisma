// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   // 'owner', 'provider'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pets      Pet[]
  services  Service[]
  subscriptions Subscription[]
}

model Pet {
  id         Int      @id @default(autoincrement())
  ownerId    Int
  name       String
  species    String
  breed      String?
  birthDate  String?
  photoUrl   String?
  weight     String?
  gender     String?
  address    String?
  city       String?
  state      String?
  contact    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner     User      @relation(fields: [ownerId], references: [id])
  vaccines  Vaccine[]
  documents Document[]
}

model Vaccine {
  id      Int      @id @default(autoincrement())
  petId   Int
  name    String
  date    String
  nextDue String?
  createdAt DateTime @default(now())

  pet     Pet      @relation(fields: [petId], references: [id])
}

model Service {
  id          Int      @id @default(autoincrement())
  providerId  Int
  type        String   // 'trainer', 'hotel', 'vet', 'petsitter'
  name        String
  description String?
  price       Float
  location    String?
  whatsapp    String?
  instagram   String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider    User     @relation(fields: [providerId], references: [id])
}

model Document {
  id        Int      @id @default(autoincrement())
  petId     Int
  type      String   // 'RG', 'BirthCert'
  status    String   @default("pending") // 'pending', 'paid', 'issued'
  stripeId  String?  // Stripe checkout session or payment intent id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pet       Pet      @relation(fields: [petId], references: [id])

  @@unique([petId, type])
}

model Subscription {
  id               Int      @id @default(autoincrement())
  userId           Int
  stripeCustomerId String?
  stripeSubId      String?
  planId           String?
  status           String   @default("inactive")
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
}
